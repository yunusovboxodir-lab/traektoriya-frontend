# =====================================================================
# .claudeignore — файлы, которые Claude НЕ должен индексировать
# Экономит токены при старте сессии (~10-15%)
# =====================================================================

# Node modules (ОГРОМНАЯ папка)
node_modules/
.pnpm-store/
.yarn/

# Vite / React builds
dist/
build/
.vite/

# Next.js (если появится)
.next/
out/

# TypeScript build artefacts
*.tsbuildinfo

# Логи
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Coverage
coverage/
.nyc_output/

# Vercel
.vercel/

# IDE
.idea/
.vscode/
*.swp
*~

# OS
.DS_Store
Thumbs.db

# Git
.git/

# Секреты
.env
.env.local
.env.production
.env*.local

# Большие бинарные / медиа
*.png
*.jpg
*.jpeg
*.gif
*.webp
*.mp4
*.mp3
*.pdf
public/uploads/

# Package lock файлы (огромные, редко нужны)
package-lock.json
yarn.lock
pnpm-lock.yaml

# Temp
*.tmp
*.temp
.cache/
